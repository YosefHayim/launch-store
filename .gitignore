# Dependencies & build output
node_modules/
dist/
*.tsbuildinfo

# Secrets — NEVER commit. Launch keeps these in the OS keychain / ~/.launch.
.env
.env.*.local
*.p8
*.p12
*.mobileprovision
*.keystore
*.jks
*.pem
AuthKey_*.p8

# Internal design docs — local-only working notes, not part of the public/published repo.
# Exception: docs/agents/ is tracked — it's the engineering-skills config agents/contributors read.
docs/*
!docs/agents/

# Launch's local state (artifacts, metadata cache)
.launch/

# Generated native projects (recreated by `expo prebuild`)
ios/
android/

# OS / editor noise
.DS_Store
*.log

# Claude Code agent worktrees / session state
.claude/
