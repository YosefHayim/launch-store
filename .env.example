# Launch reads this app's client-facing configuration from `.env` at build time and
# makes it available to the app (via the generated config's `extra` field during prebuild).
#
# IMPORTANT: there is no `EXPO_PUBLIC_` prefix guard here — everything in `.env` can end up
# inside the shipped app bundle. Keep BACKEND secrets (database URLs, service keys, signing
# secrets) OUT of this file; those belong with your backend, not in a build.
#
# `.env.example` is the committed template; copy it to `.env` (gitignored) and fill in values.
# `launch build` validates `.env` against this file and fails early if a key is missing.

API_URL=
STATIC_CDN_URL=
SUPABASE_PROJECT_ID=
SUPABASE_PUBLISHABLE_KEY=
GOOGLE_WEB_CLIENT_ID=
DEV_FORCE_PRO=
