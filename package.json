{
  "name": "launch-store",
  "version": "0.11.0",
  "description": "Build and ship your iOS/Android apps to the stores from your own machine, with your own keys — no Expo bill.",
  "keywords": [
    "cli",
    "mobile",
    "ios",
    "android",
    "app-store",
    "testflight",
    "play-store",
    "fastlane",
    "react-native",
    "expo",
    "eas",
    "code-signing",
    "app-store-connect",
    "ci-cd"
  ],
  "homepage": "https://github.com/YosefHayim/launch-store#readme",
  "bugs": {
    "url": "https://github.com/YosefHayim/launch-store/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/YosefHayim/launch-store.git"
  },
  "author": "YosefHayim",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "launch": "dist/cli/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.build.json && chmod +x dist/cli/index.js",
    "dev": "tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "launch": "tsx src/cli/index.ts",
    "prepare": "husky",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "commander": "^12.1.0",
    "jiti": "^2.4.0",
    "jose": "^5.9.6"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@vitest/coverage-v8": "^4.1.8",
    "eslint": "^9.13.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "src/**/*.ts": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "optionalDependencies": {
    "@aws-sdk/client-ec2": "^3.1068.0",
    "@aws-sdk/client-s3": "^3.1068.0",
    "@aws-sdk/credential-providers": "^3.1068.0",
    "@napi-rs/keyring": "^1.3.0"
  }
}
