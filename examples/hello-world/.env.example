# Template of the env keys this app reads. Copy to `.env` (gitignored) to override values locally.
#
# Committed, non-secret config per profile lives in `.env.production` / `.env.preview` (see
# launch.config.ts). This template just documents the full key set. Real secrets belong in
# `launch secret` — never in any committed .env file (Launch warns on secret-looking names).
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_ENV=
