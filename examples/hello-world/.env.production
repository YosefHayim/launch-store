# Committed, NON-SECRET build-time config for the `production` profile (launch.config.ts → envFile).
# Everything here is bundled into the app, so keep it public-safe. Real secrets (API keys, tokens) go
# in `launch secret`, which resolves above these files in the env ladder — never commit secrets here.
EXPO_PUBLIC_API_URL=https://api.helloworld.example
EXPO_PUBLIC_ENV=production
