# Committed, NON-SECRET build-time config for the `preview` profile (launch.config.ts → envFile).
# The preview profile also sets EXPO_PUBLIC_DEBUG_OVERLAY inline in launch.config.ts, which layers on
# top of this file (inline `env` outranks dotenv files in the resolution ladder).
EXPO_PUBLIC_API_URL=https://staging.api.helloworld.example
EXPO_PUBLIC_ENV=preview
