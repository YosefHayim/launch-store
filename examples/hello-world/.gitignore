# Standalone-example ignores (the repo root .gitignore already covers most of these). Kept here so this
# folder stays copy-pasteable into a fresh project.
node_modules/
.expo/
dist/
web-build/

# Native projects are generated by `expo prebuild` / Launch — never committed.
ios/
android/

# Local secrets. Committed profile config lives in .env.production / .env.preview instead.
.env
.env*.local
